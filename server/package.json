{
  "name": "ai-venture-studio-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "check": "powershell -NoProfile -Command \"Get-ChildItem -Recurse -Filter *.js . | Where-Object { $_.FullName -notmatch '\\\\node_modules\\\\' } | ForEach-Object { node --check $_.FullName }\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "pdfkit": "^0.15.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
