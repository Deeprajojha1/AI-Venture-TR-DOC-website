PORT=5000
CLIENT_ORIGIN=http://localhost:5173
MEMORY_STORE=false

MONGODB_URI=mongodb://username:password@host:27017/ai-venture-studio
MONGODB_DATABASE=ai-venture-studio
MONGODB_CONNECT_TIMEOUT_MS=3000
JWT_SECRET=change-me-before-production

GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.1-8b-instant

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

TAVILY_API_KEY=your_tavily_key_here

RESEND_API_KEY=your_resend_key_here
RESEND_FROM="AI Venture Studio <onboarding@resend.dev>"
RESEND_REPLY_TO=you@example.com
